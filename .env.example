# ===========================================
# Commerce Platform - Environment Configuration
# ===========================================
# Copy this file to .env and update values

# --- MongoDB ---
MONGO_PORT=27017
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin123
MONGO_DB=commerce_platform

# --- Redis ---
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# --- Backend ---
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=change-this-to-a-secure-256-bit-secret-key-in-production
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend ---
FRONTEND_PORT=5173

# --- Rate Limiting ---
RATE_LIMIT_RPM=60

# --- Feature Flags ---
FF_CHANNEL_SYNC=true
FF_AUDIT_LOG=true
FF_NOTIFICATIONS=false

# --- Shutdown ---
SHUTDOWN_MAX_WAIT=30
